---
import '../styles/global.css';
import TopMenu from '../components/TopMenu.astro';

interface Props {
	lang?: 'en' | 'pt';
	title?: string;
	/** Optional class to wrap content in (e.g. "docs-content" for MDX docs). */
	contentClass?: string;
	frontmatter?: { lang?: string; title?: string; contentClass?: string };
}
const { lang: propLang, title: propTitle, contentClass: propContentClass, frontmatter } = Astro.props;
// MDX passes frontmatter under .frontmatter; .astro pages pass at top level
const langFromProps = propLang ?? frontmatter?.lang;
const title = propTitle ?? frontmatter?.title ?? 'CommitPT';
const contentClass = propContentClass ?? frontmatter?.contentClass;
const pathSegment = Astro.url.pathname.split('/').filter(Boolean)[0];
const lang: 'en' | 'pt' =
	(langFromProps === 'pt' || langFromProps === 'en' ? langFromProps : null) ??
	(pathSegment === 'pt' || pathSegment === 'en' ? pathSegment : 'en');
---
<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>CommitPT — {String(title)}</title>
		<link rel="alternate" hreflang="en" href="/en/" />
		<link rel="alternate" hreflang="pt" href="/pt/" />
		<link rel="alternate" hreflang="x-default" href="/en/" />
	</head>
	<body>
		<TopMenu lang={lang} />
		{contentClass ? (
			<main class={contentClass}>
				<slot />
			</main>
		) : (
			<slot />
		)}
	</body>
</html>
