---
import '../styles/global.css';
import TopMenu from '../components/TopMenu.astro';

interface Props {
	lang?: 'en' | 'pt';
	title?: string;
	/** Optional class to wrap content in (e.g. "docs-content" for MDX docs). */
	contentClass?: string;
}
const { lang: propLang, title = 'CommitPT', contentClass } = Astro.props;
// Derive lang from URL when not passed (e.g. from MDX frontmatter)
const pathSegment = Astro.url.pathname.split('/').filter(Boolean)[0];
const lang =
	propLang ?? (pathSegment === 'pt' || pathSegment === 'en' ? pathSegment : 'en');
---
<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>CommitPT — {title}</title>
		<link rel="alternate" hreflang="en" href="/en/" />
		<link rel="alternate" hreflang="pt" href="/pt/" />
		<link rel="alternate" hreflang="x-default" href="/en/" />
	</head>
	<body>
		<TopMenu lang={lang} />
		{contentClass ? (
			<main class={contentClass}>
				<slot />
			</main>
		) : (
			<slot />
		)}
	</body>
</html>
