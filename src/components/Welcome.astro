---
import background from "../assets/background.svg";
import type { Translations } from "../i18n";
import ConstructionNotice from "./ConstructionNotice";
import DiscordButton from "./DiscordButton";

interface Props {
  t: Translations;
}
const { t } = Astro.props;
---

<div class="h-full md:flex md:flex-col">
  <img
    class="fixed inset-0 w-full h-full -z-10 blur-[100px]"
    src={background.src}
    alt=""
    fetchpriority="high"
  />
  <main class="h-full flex justify-center">
    <section class="flex flex-col items-start justify-center p-4 md:block md:pt-[10%]">
      <h1 class="m-0 text-gray-900 text-4xl font-bold tracking-tight md:text-3xl md:leading-tight">
        CommitPT
      </h1>
      <p class="text-gray-500 text-xl font-medium mt-1 mb-4">
        {t.tagline}
      </p>
      <p class="max-w-[420px] text-gray-500 text-base leading-relaxed mb-4">
        {t.overview}
      </p>
      <div class="mb-6 w-full max-w-[420px]">
        <ConstructionNotice client:load strong={t.constructionStrong} rest={t.constructionRest} />
      </div>
      <section class="flex gap-4 flex-wrap">
        <DiscordButton
          client:load
          href="https://discord.gg/yGAbprCBrT"
          label={t.joinDiscord}
          ariaLabel={t.joinDiscordAria}
        />
      </section>
    </section>
  </main>
</div>
