---
import background from "../assets/background.svg";
import type { Translations } from "../i18n";

interface Props {
  t: Translations;
}
const { t } = Astro.props;
---

<div class="h-full md:flex md:flex-col">
  <img
    class="fixed inset-0 w-full h-full -z-10 blur-[100px]"
    src={background.src}
    alt=""
    fetchpriority="high"
  />
  <main class="h-full flex justify-center">
    <section class="flex flex-col items-start justify-center p-4 md:block md:pt-[10%]">
      <h1 class="m-0 text-gray-900 text-4xl font-bold tracking-tight md:text-3xl md:leading-tight">
        CommitPT
      </h1>
      <p class="text-gray-500 text-xl font-medium mt-1 mb-4">
        {t.tagline}
      </p>
      <p class="max-w-[420px] text-gray-500 text-base leading-relaxed mb-4">
        {t.overview}
      </p>
      <p class="text-gray-400 text-[0.9375rem] mb-6 py-3 px-4 bg-white/60 rounded-lg border border-black/5 [&>strong]:text-gray-700">
        <strong>{t.constructionStrong}</strong>
        {t.constructionRest}
      </p>
      <section class="flex gap-4 flex-wrap">
        <a
          class="flex items-center py-2.5 px-3 text-white no-underline rounded-lg transition-colors hover:text-gray-200 bg-[linear-gradient(83.21deg,#3245ff_0%,#bc52ee_100%)] shadow-[inset_0_0_0_1px_rgba(255,255,255,0.12),inset_0_-2px_0_rgba(0,0,0,0.24)] hover:shadow-none md:py-3.5 md:px-[18px]"
          href="https://discord.gg/yGAbprCBrT"
          aria-label={t.joinDiscordAria}
        >
          {t.joinDiscord}
          <svg
            class="h-[1em] ml-2"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 127.14 96.36"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="M107.7 8.07A105.15 105.15 0 0 0 81.47 0a72.06 72.06 0 0 0-3.36 6.83 97.68 97.68 0 0 0-29.11 0A72.37 72.37 0 0 0 45.64 0a105.89 105.89 0 0 0-26.25 8.09C2.79 32.65-1.71 56.6.54 80.21a105.73 105.73 0 0 0 32.17 16.15 77.7 77.7 0 0 0 6.89-11.11 68.42 68.42 0 0 1-10.85-5.18c.91-.66 1.8-1.34 2.66-2a75.57 75.57 0 0 0 64.32 0c.87.71 1.76 1.39 2.66 2a68.68 68.68 0 0 1-10.87 5.19 77 77 0 0 0 6.89 11.1 105.25 105.25 0 0 0 32.19-16.14c2.64-27.38-4.51-51.11-18.9-72.15ZM42.45 65.69C36.18 65.69 31 60 31 53s5-12.74 11.43-12.74S54 46 53.89 53s-5.05 12.69-11.44 12.69Zm42.24 0C78.41 65.69 73.25 60 73.25 53s5-12.74 11.44-12.74S96.23 46 96.12 53s-5.04 12.69-11.43 12.69Z"
            />
          </svg>
        </a>
      </section>
    </section>
  </main>
</div>
