---
interface Props {
  lang: 'en' | 'pt';
}
const { lang } = Astro.props;
const homeUrl = `/${lang}/`;
const docsUrl = `/${lang}/docs/`;
---
<header class="sticky top-0 z-10 bg-white/85 backdrop-blur-xl border-b border-black/5">
  <nav class="flex items-center gap-6 max-w-6xl mx-auto px-4 py-3" aria-label="Main">
    <a class="font-bold text-lg text-gray-900 no-underline mr-2 hover:text-gray-700" href={homeUrl}>CommitPT</a>
    <a class="text-gray-500 text-[0.9375rem] no-underline hover:text-gray-900" href={docsUrl}>Docs</a>
  </nav>
</header>
