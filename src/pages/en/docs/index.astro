---
import Layout from '../../../layouts/Layout.astro';
import { getTranslations } from '../../../i18n';

const lang = 'en';
const t = getTranslations(lang);
---

<Layout lang={lang} title={t.docsTitle}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <h1 class="text-2xl text-gray-900 m-0 mb-6">{t.docsTitle}</h1>
    <ul class="list-none m-0 p-0">
      <li>
        <a
          class="block py-3 text-gray-600 no-underline border-b border-black/5 hover:text-gray-900"
          href="/en/docs/getting-started/"
        >
          {t.gettingStarted}
        </a>
      </li>
    </ul>
  </div>
</Layout>
