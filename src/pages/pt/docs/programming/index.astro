---
import Layout from "../../../../layouts/Layout.astro";
import { getTranslations } from "../../../../i18n";

const lang = "pt";
const t = getTranslations(lang);
---

<Layout lang={lang} title={t.programming}>
  <div class="docs-content">
    <h1 class="text-2xl font-semibold text-foreground m-0 mb-4">{t.programming}</h1>
    <p class="text-muted-foreground m-0">Conteúdo em breve.</p>
  </div>
</Layout>
